{
  "name": "ghost",
  "version": "1.0.0",
  "description": "GHOST — AI Interview Copilot. Invisible during screen sharing.",
  "main": "main.js",
  "scripts": {
    "start": "electronmon .",
    "start:prod": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron": "^33.0.0",
    "koffi": "^2.15.2"
  },
  "devDependencies": {
    "electron-builder": "^25.0.0",
    "electronmon": "^2.0.3"
  },
  "build": {
    "appId": "com.ghost.app",
    "productName": "GHOST",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "files": [
      "main.js",
      "preload.js",
      "stealth.js",
      "renderer/**/*"
    ]
  }
}
